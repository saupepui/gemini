---
// src/components/Simulador.astro
const { coche } = Astro.props;
---

<div id="simulador"
     class="bg-white rounded-lg shadow-xl p-8 max-w-lg mx-auto my-10 border border-gray-200 text-gray-800"
     data-bateria={coche.bateria_util_kwh}
     data-consumo={coche.consumo_medio_kwh_100km}>
  <h2 class="text-3xl font-extrabold mb-6 text-center text-indigo-700">Simulador de Carga</h2>

  <div class="space-y-6">
    <div>
      <label for="precioKwh" class="block text-sm font-semibold text-gray-700 mb-1">Precio del kWh (€)</label>
      <input type="text" id="precioKwh" value="0.15" step="0.01"
             class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-base p-2.5 bg-gray-50 hover:border-gray-400 transition duration-200 ease-in-out" />
    </div>

    <div>
      <label for="potenciaCarga" class="block text-sm font-semibold text-gray-700 mb-1">Potencia de carga doméstica (kW)</label>
      <input type="text" id="potenciaCarga" value="7.4" step="0.1"
             class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-base p-2.5 bg-gray-50 hover:border-gray-400 transition duration-200 ease-in-out" />
    </div>
  </div>

  <div class="mt-8 pt-6 border-t border-gray-200">
    <p class="text-xl flex justify-between items-center mb-3">Coste por 100km: <span id="resultadoCoste" class="font-bold text-indigo-600 text-2xl">--</span> €</p>
    <p class="text-xl flex justify-between items-center">Tiempo de carga 0-100%: <span id="resultadoTiempo" class="font-bold text-indigo-600 text-2xl">--</span> horas</p>
  </div>
</div>

<script>
  const simuladorDiv = document.getElementById('simulador');
  const bateria = parseFloat(simuladorDiv.getAttribute('data-bateria')) || 0;
  const consumo = parseFloat(simuladorDiv.getAttribute('data-consumo')) || 0;

  const inputPrecio = document.getElementById('precioKwh') as HTMLInputElement;
  const inputPotencia = document.getElementById('potenciaCarga') as HTMLInputElement;
  const elCoste = document.getElementById('resultadoCoste');
  const elTiempo = document.getElementById('resultadoTiempo');

  const calcularCoste100km = (consumo: number, precioKwh: number) => consumo * precioKwh;
  const calcularTiempoDomestica = (bateria: number, potenciaCargador: number) => potenciaCargador <= 0 ? Infinity : bateria / potenciaCargador;

  function actualizar() {
    const precio = parseFloat(inputPrecio.value.replace(',', '.')) || 0;
    const potencia = parseFloat(inputPotencia.value.replace(',', '.')) || 1;

    const coste = calcularCoste100km(consumo, precio);
    const tiempo = calcularTiempoDomestica(bateria, potencia);

    if (elCoste) elCoste.textContent = coste.toFixed(2);
    if (elTiempo) elTiempo.textContent = tiempo.toFixed(1);
  }

  inputPrecio?.addEventListener('input', actualizar);
  inputPotencia?.addEventListener('input', actualizar);

  // Calcular inicial
  actualizar();
</script>