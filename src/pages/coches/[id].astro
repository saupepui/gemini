---
import { getStaticPaths as getStaticPathsBase } from 'astro';
import coches from '../../data/coches.json';

export async function getStaticPaths() {
  return coches.map((coche) => ({
    params: { id: coche.id },
    props: { coche },
  }));
}

import Simulador from '../../components/Simulador.astro';

const { coche } = Astro.props;

// Mapeo simple de los datos para el simulador
const cocheParaSimulador = {
  bateria: coche.bateria_util_kwh,
  consumo: coche.consumo_medio_kwh_100km
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{coche.marca} {coche.modelo}</title>
  </head>
  <body class="bg-gray-100 p-8">
    <main class="max-w-2xl mx-auto space-y-8">
      <div class="bg-white p-6 rounded shadow">
        <h1 class="text-3xl font-bold text-gray-800">{coche.marca} {coche.modelo}</h1>
        <p class="text-gray-600 mt-2">Batería: {coche.bateria_util_kwh} kWh | Consumo: {coche.consumo_medio_kwh_100km} kWh/100km</p>
      </div>

      <Simulador coche={cocheParaSimulador} />
    </main>
  </body>
</html>
